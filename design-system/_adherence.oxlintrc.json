      "--fg1",
      "--fg2",
      "--fg3",
      "--font-display",
      "--font-mono",
      "--font-sans",
      "--font-serif-text",
      "--fs-body",
      "--fs-caption",
      "--fs-claim",
      "--fs-display",
      "--fs-eyebrow",
      "--fs-h1",
      "--fs-h2",
      "--fs-h3",
      "--fs-h4",
      "--fs-small",
      "--lh-body",
      "--lh-display",
      "--lh-loose",
      "--lh-snug",
